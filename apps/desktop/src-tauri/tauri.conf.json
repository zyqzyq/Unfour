{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unfour",
  "version": "0.1.2",
  "identifier": "dev.unfour",
  "build": {
    "beforeDevCommand": "node ../../scripts/sync-version.mjs && node ../../scripts/prepare-tauri-sidecars.mjs --debug && pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ../../scripts/sync-version.mjs && pnpm run build && node ../../scripts/prepare-tauri-sidecars.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Unfour",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage", "rpm"],
    "externalBin": [
      "binaries/unfour-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
